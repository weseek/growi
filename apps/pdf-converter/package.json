{
  "name": "@growi/pdf-converter",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:pdf-converter": "nodemon -r \"dotenv-flow/config\" src/index.ts",
    "lint": "pnpm eslint **/*.{js,ts}",
